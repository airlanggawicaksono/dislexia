POSTGRES_IMAGE=postgres:16-alpine
DB_USER=postgres
DB_PASSWORD=devpassword123
DB_NAME=dislexia_dev
DB_HOST=postgres-db
DB_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
APP_PORT=8000
APP_EXTERNAL_PORT=8000
APP_HOST=0.0.0.0
APP_RELOAD=true
JWT_SECRET_KEY=dev-secret-key-change-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development

# CORS
# Comma-separated list of allowed origins. Use "*" to allow any origin (dev only).
CORS_ALLOW_ORIGINS=https://reader.dyslexic.app,http://localhost:8083
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_EXPOSE_HEADERS=
CORS_MAX_AGE=600
