meta {
  name: Professionalize - Process
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/me/professionalize/process
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "text": "yo so basically i think we should prolly meet up next week and chat about the project stuff cuz things are kinda all over the place rn"
  }
}

script:post-response {
  const body = res.getBody();
  if (body.session_id) bru.setEnvVar("session_id", body.session_id);
  if (body.history_id) bru.setEnvVar("history_id", body.history_id);
}

assert {
  res.status: eq 200
  res.body.feature: eq professionalize
  res.body.result: isDefined
}
