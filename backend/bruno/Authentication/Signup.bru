meta {
  name: Signup
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/v1/auth/signup
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{test_email}}"
  }
}

vars:pre-request {
  test_email: tehhkkst@teast.com
  base_url: https://dev.dyslexic.app
}

assert {
  res.status: eq 201
  res.body.access_code: length 7
}

script:post-response {
  const body = res.getBody();
  bru.setVar("access_code", body.access_code);
}
